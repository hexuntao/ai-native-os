# ============ Base ============
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
PORT=3001

# ============ Database ============
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ai_native_os

# ============ Redis ============
# 优先使用 REDIS_URL；只有在无法提供 URL 时才拆分 host/port/password。
REDIS_URL=redis://:redis@localhost:6380
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_HEALTH_TIMEOUT_MS=1500

# ============ Auth ============
BETTER_AUTH_SECRET=replace-with-32-char-secret
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# ============ AI Runtime ============
# 生产环境下的 RAG embedding 必须提供 OPENAI_API_KEY。
OPENAI_API_KEY=
MASTRA_DEFAULT_MODEL=openai/gpt-4.1-mini
MASTRA_OPENAPI_PATH=/openapi.json
MASTRA_ROUTE_PREFIX=/mastra
MASTRA_RAG_EMBEDDING_MODEL=text-embedding-3-small

# ============ External MCP ============
EXTERNAL_MCP_SERVER_URL=
EXTERNAL_MCP_AUTH_HEADER_NAME=
EXTERNAL_MCP_AUTH_HEADER_VALUE=

# ============ Jobs / Trigger.dev ============
TRIGGER_PROJECT_REF=proj_replace_me
TRIGGER_SECRET_KEY=
TRIGGER_API_URL=https://api.trigger.dev

# ============ Observability ============
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=ai-native-os-api
TELEMETRY_TRACES_SAMPLE_RATE=1

# 说明：
# - Cloudflare / Vercel 的部署凭据与 Worker bindings 不放在这里，见 docs/environment-matrix.md。
# - 当前仓库的真实运行时契约以 docs/environment-matrix.md 为准。
