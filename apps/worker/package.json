{
  "name": "@ai-native-os/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "deploy:cloudflare:prod": "pnpm dlx wrangler@latest deploy --config wrangler.toml",
    "deploy:cloudflare:prod:dry-run": "pnpm dlx wrangler@latest deploy --config wrangler.toml --dry-run",
    "deploy:cloudflare:staging": "pnpm dlx wrangler@latest deploy --config wrangler.toml --env staging",
    "deploy:cloudflare:staging:dry-run": "pnpm dlx wrangler@latest deploy --config wrangler.toml --env staging --dry-run",
    "dev": "tsx watch src/index.ts",
    "format": "biome check --write .",
    "lint": "biome check .",
    "test": "tsx --test $(find src -type f -name '*.test.ts' | sort)",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest"
  }
}
